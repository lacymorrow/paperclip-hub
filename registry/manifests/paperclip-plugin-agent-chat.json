        {
          "type": "page",
          "id": "chat-page",
          "displayName": "Agent Chat",
          "exportName": "ChatPage",
          "routePath": "agent-chat"
        },
        {
          "type": "detailTab",
          "id": "chat-agent-tab",
          "displayName": "Chat",
          "exportName": "ChatAgentTab",
          "entityTypes": [
            "agent"
          ],
          "order": 5
        }
      ]
    }
  },
  "resolvedAt": "2026-06-02T07:55:10.783Z"
