{
  "name": "cliphub",
  "version": "0.1.0",
  "homepage": "https://cliphub.fyi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lacymorrow/paperclip-hub.git"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "bun scripts/registry/build-index.ts && next build",
    "build:vercel": "bun scripts/registry/build-index.ts && NODE_OPTIONS='--max-old-space-size=8192' next build --turbo",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "rm -rf .next node_modules .turbo",
    "registry:build-index": "bun scripts/registry/build-index.ts",
    "registry:refresh": "bun scripts/registry/extract-manifest.ts --refresh"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@radix-ui/react-icons": "1.3.2",
    "@t3-oss/env-core": "^0.13.10",
    "@t3-oss/env-nextjs": "0.13.10",
    "@vercel/otel": "^2.1.0",
    "acorn": "^8.16.0",
    "ajv": "^8",
    "ajv-formats": "^3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.564.0",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.1",
    "tailwind-merge": "3.4.1",
    "tar-stream": "^3.2.0",
    "web-haptics": "^0.0.6",
    "zod": "3.25.74"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "25.2.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.0.0",
    "@types/tar-stream": "^3.1.4",
    "autoprefixer": "10.4.24",
    "babel-plugin-react-compiler": "^1.0.0",
    "postcss": "8.5.6",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "1.0.7",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
